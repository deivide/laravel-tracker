{
    "name": "deivide/laravel-tracker",
    "description": "A Laravel Visitor Tracker - Maintained fork of pragmarx/tracker",
    "keywords": [
        "tracker",
        "tracking",
        "visitor",
        "logging",
        "user agent",
        "mobile detection",
        "laravel",
        "pragmarx"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Antonio Carlos Ribeiro",
            "email": "acr@antoniocarlosribeiro.com",
            "role": "Original Creator (pragmarx/tracker)"
        },
        {
            "name": "Deivide",
            "homepage": "https://github.com/deivide",
            "role": "Maintainer (Fork)"
        }
    ],
    "repositories": [
        {
            "type": "git",
            "name": "pragmarx/datatables",
            "url": "https://github.com/deivide/laravel4-datatables-package.git"
        },
        {
            "type": "git",
            "name": "pragmarx/support",
            "url": "https://github.com/deivide/support.git"
        }
    ],
    "require": {
        "php": ">=8.0",
        "doctrine/dbal": "^2.6|^3.1",
        "laravel/framework": "~5|~6|~7|~8|~9|~10|~11",
        "pragmarx/support": "dev-master",
        "ramsey/uuid": "^3 || ^4",
        "jenssegers/agent": "~2.1",
        "ua-parser/uap-php": "~3.4",
        "pragmarx/datatables": "dev-master",
        "snowplow/referer-parser": "~0.1",
        "jaybizzle/crawler-detect": "~1.0",
        "psr/log": "^1.1 || ^2.0 || ^3.0"
    },
    "suggest": {
        "geoip/geoip": "~1.14",
        "geoip2/geoip2": "~2.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.0",
        "phpunit/phpunit": "^9.0|^10.0|^11.0",
        "orchestra/testbench": "^6.0|^7.0|^8.0|^9.0"
    },
    "autoload": {
        "psr-4": {
            "PragmaRX\\Tracker\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PragmaRX\\Tracker\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "3.3.x-dev"
        },
        "laravel": {
            "providers": [
                "PragmaRX\\Tracker\\Vendor\\Laravel\\ServiceProvider"
            ],
            "aliases": {
                "Tracker": "PragmaRX\\Tracker\\Vendor\\Laravel\\Facade"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}